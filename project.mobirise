            },
            ".mbr-section-title": {
              "color": "#000000",
              "text-align": "center"
            },
            ".mbr-text, .item .mbr-section-btn": {
              "text-align": "left"
            },
            ".item-wrapper": {
              "background": "@cardbg",
              "margin-bottom": "2rem",
              "@media (max-width: 767px)": {
                "padding": "2rem 1.5rem",
                "margin-bottom": "1rem"
              },
              "@media (min-width: 768px) and (max-width: 991px)": {
                "padding": "2.25rem"
              },
              "@media (min-width: 992px)": {
                "padding": "4rem"
              }
            },
            ".counter-container": {
              "ul": {
                "margin": "0",
                "padding-left": "2.25rem",
                "list-style": "none",
                "li": {
                  "position": "relative",
                  "list-style": "none",
                  "margin-bottom": "1rem",
                  "&:before": {
                    "position": "absolute",
                    "left": "-1.5em",
                    "content": "\"\"",
                    "display": "flex",
                    "justify-content": "center",
                    "align-items": "center",
                    "color": "@iconColor",
                    "background-color": "@iconColor",
                    "width": "0.5em",
                    "height": "0.5em",
                    "top": "0.4em",
                    "border-radius": "50%"
                  }
                }
              }
            },
            ".mbr-text UL": {
              "text-align": "left"
            },
            ".mbr-card-subtitle": {
              "color": "#232323",
              "text-align": "left"
            }
          },
          "_name": "list06",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list06\" group=\"List\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"9\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showMainTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showMainSubtitle\">\n        <input type=\"checkbox\" title=\"Position\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Date\" name=\"showSubtitle\">\n        <input type=\"checkbox\" title=\"List 1\" name=\"showList1\" checked>\n        <input type=\"checkbox\" title=\"List 2\" name=\"showList2\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"Card BG\" name=\"cardbg\" value=\"#ffffff\" selected>\n        <input type=\"color\" title=\"Bullet Color\" name=\"iconColor\" value=\"#000000\" selected>\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#edefeb\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"col-12 mb-5 content-head\" mbr-if=\"showMainTitle || showMainSubtitle\">\n            <h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showMainTitle\" data-app-selector=\".mbr-section-title\"><div><b>ΒΙΟΓΡΑΦΙΚΟ</b></div></h3>\n            <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4\" mbr-theme-style=\"display-7\" mbr-if=\"showMainSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n                Lorem ipsum dolor sit amet, consectetur adipiscing elit.\n            </h5>\n        </div>\n        <div class=\"row justify-content-center \">\n            <div class=\" col-12 col-lg-{{textWidth}}\">\n                \n                <div class=\"item features-without-image col-12 active\">\n                    <div class=\"item-wrapper\">\n                        <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-5\"><b>Dr.&nbsp; ΑΣΠΑΣΙΑ ΣΤΕΦΑΝΙΩΤΟΥ MD MSc - ΑΚΤΙΝΟΔΙΑΓΝΩΣΗ&nbsp;</b><div><br></div></h5>\n                        <h6 class=\"mbr-card-subtitle mbr-fonts-style mt-0 mb-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-card-subtitle\" mbr-theme-style=\"display-7\"></h6>\n                        <h6 class=\"mbr-card-subtitle mbr-fonts-style mt-0 mb-3\" mbr-if=\"showList1\" data-app-selector=\".mbr-card-subtitle\" mbr-theme-style=\"display-7\"></h6>\n                        <div class=\"counter-container mbr-text mbr-fonts-style\" mbr-if=\"showList1\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" data-multiline mbr-article>\n                            <ul>\n                                <li>Ιατρός - Ακτινοδιαγνώστης, απόφοιτη της Ιατρικής Σχολής Εθνικού &amp; Καποδιστριακού Πανεπιστημίου Αθηνών (ΕΚΠΑ) και υποψήφια Διδάκτωρ Ιατρικής Σχολής (ΕΚΠΑ).\n</li><li>Κάτοχος μεταπτυχιακών τίτλων (MSc) στην Επεμβατική Ακτινολογία, στo Σχεδιασμό Υγείας &amp; Πολιτική Υγείας και στη Διοίκηση Μονάδων Υγείας.\n</li><li>Εξειδικευθείσα στο SLK Klinikum - Τμήμα Επεμβατικής Ακτινολογίας |Χαϊλμπρόν, Γερμανία\n</li><li>Πολυετής εμπειρία στην προηγμένη ιατρική απεικόνιση και εξειδίκευση στη διάγνωση παθήσεων μαστού.\n</li><li>Κλινική εμπειρία στη μαστογραφία, την ελαστογραφία, τις υπερηχογραφικά καθοδηγούμενες βιοψίες και την τοποθέτηση προεγχειρητικού συρμάτινου οδηγού (Hook)\n</li><li>Συνεχής επιστημονική εξέλιξη και εφαρμογή καινοτόμων τεχνικών απεικόνισης, συμβάλλοντας ενεργά στη βελτίωση της διαγνωστικής ακτινολογίας.</li>\n                            </ul>\n                        </div>\n                        <h6 class=\"mbr-card-subtitle mbr-fonts-style mt-0 mb-3\" mbr-if=\"showList2\" data-app-selector=\".mbr-card-subtitle\" mbr-theme-style=\"display-7\"><b>Επιστημονικά Υπέυθυνη</b></h6>\n                        <div class=\"counter-container mbr-text mbr-fonts-style\" mbr-if=\"showList2\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" data-multiline mbr-article><p>Κέντρου Υπερήχων &amp; Μαστογραφίας ΑΚΤΙΝΟΔΙΑΓΝΩΣΗ | Πειραιάς, Κορυδαλλός</p><p>\n</p><div><b>Υπεύθυνη Τμήματος Ιατρικής Απεικόνισης</b></div><div><b><br></b></div><div><b> \n</b></div><div>Κεντρική Κλινική Αθηνών &amp; Ιδιωτικό Πολυϊατρείο Σαντορίνης | Αθήνα, Σαντορίνη</div><div><br></div><div>\n</div><div><b>Ιατρός Ακτινοδιαγνώστης</b></div><div><b><br></b></div><div><b>\n</b></div><div>Νοσοκομείο Μητέρα - Τμήμα Απεικόνισης Μαστού | Αθήνα\n</div><div><br></div><p></p></div>\n                        <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                Learn more</a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uPZnjjOrfE",
          "_anchor": "list06-1w",
